# Let Git detect text vs. binary and normalize line endings on commit.
* text=auto eol=lf

# Source and configuration -- enforce LF.
*.java         text eol=lf
*.xml          text eol=lf
*.properties   text eol=lf
*.yml          text eol=lf
*.md           text eol=lf
*.svg          text eol=lf
*.cff          text eol=lf

# Tooling dotfiles -- enforce LF.
.editorconfig  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Binary assets -- never normalize or diff as text.
*.pdf  binary
*.png  binary
